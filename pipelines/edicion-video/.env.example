# Copia este fichero a .env y rellena tus claves
# cp .env.example .env

# OpenAI API — Whisper (transcripción) + GPT (opcional para automatización)
OPENAI_API_KEY=sk-...

# Idioma por defecto para transcripción (es = español, en = inglés, auto = detectar)
TRANSCRIPTION_LANGUAGE=es

# Directorio de trabajo (por defecto: junto a los vídeos de entrada)
# EDIT_DIR=./edit
