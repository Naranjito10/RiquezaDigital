    {
      "id": "node-find-worst",
      "name": "Identificar Peores",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [5440, 300],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const cfg = $('Extraer IDs').first().json;\nconst ads = $input.first().json.data || [];\nconst MIN_SPEND = cfg.WORST_MIN_SPEND || 10;\nconst MAX_PAUSE = cfg.MAX_ADS_TO_PAUSE || 2;\n\nconst withMetrics = ads.map(ad => {\n  const ins = ad.insights?.data?.[0] || {};\n  return {\n    id: ad.id,\n    name: ad.name,\n    spend: parseFloat(ins.spend || 0),\n    ctr: parseFloat(ins.ctr || 0),\n    cpl: parseFloat(ins.cost_per_result || 999),\n    impressions: parseInt(ins.impressions || 0)\n  };\n});\n\nconst eligible = withMetrics.filter(a => a.spend >= MIN_SPEND);\nif (eligible.length === 0) return [{ json: { worstPerformers: [] } }];\n\nconst avgCTR = eligible.reduce((s, a) => s + a.ctr, 0) / eligible.length;\nconst worst = eligible\n  .filter(a => a.ctr < avgCTR * 0.5 || a.cpl > 999)\n  .sort((a, b) => a.ctr - b.ctr)\n  .slice(0, MAX_PAUSE);\n\nreturn worst.length > 0 ? worst.map(w => ({ json: w })) : [{ json: { worstPerformers: [] } }];"
      }
    },
