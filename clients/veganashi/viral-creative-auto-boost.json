    },
    {
      "id": "node-get-insights",
      "name": "GET Insights",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2060, 300],
      "parameters": {
        "method": "GET",
        "url": "=https://graph.facebook.com/v21.0/{{ $json.media_id }}/insights",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "Authorization", "value": "=Bearer {{ $json.META_TOKEN }}" }]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [{ "name": "metric", "value": "impressions,reach,saved,video_views" }]
        }
      }
    },
    {
      "id": "node-eval-viral",
      "name": "Evaluar Viral",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2320, 300],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const prev = $('Filtrar Videos').item.json;\nconst insights = $input.item.json.data || [];\nconst get = (name) => (insights.find(i => i.name === name)?.values?.[0]?.value) || 0;\nconst views = get('video_views');\nconst reach = get('reach');\nconst saves = get('saved');\nconst likes = prev.like_count || 0;\nconst comments = prev.comments_count || 0;\nconst engagementRate = reach > 0 ? (likes + comments + saves) / reach : 0;\nconst isViral = views >= prev.VIRAL_MIN_VIEWS && saves >= prev.VIRAL_MIN_SAVES && engagementRate >= prev.VIRAL_MIN_ENGAGEMENT_RATE;\nreturn { json: { ...prev, views, reach, saves, engagementRate, isViral } };"
      }
    },
    {
      "id": "node-if-viral",
      "name": "Es Viral?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [2580, 300],
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [{ "id": "c1", "leftValue": "={{ $json.isViral }}", "rightValue": true, "operator": { "type": "boolean", "operation": "true" } }],
          "combinator": "and"
        }
      }
    },
