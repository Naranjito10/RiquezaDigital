    {
      "id": "node-check-duplicate",
      "name": "Ya tiene Ad?",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3100, 300],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const videoData = $('Evaluar Viral').item.json;\nconst ads = $input.item.json.data || [];\nconst mediaId = videoData.media_id;\nconst alreadyRunning = ads.some(ad => {\n  const storyId = ad.creative?.object_story_id || '';\n  return storyId.includes(mediaId);\n});\nreturn { json: { ...videoData, alreadyRunning } };"
      }
    },
