    {
      "id": "node-filter-videos",
      "name": "Filtrar Videos",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1540, 300],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const cfg = $('Extraer IDs').first().json;\nconst media = $input.first().json.data || [];\nconst videos = media.filter(m => m.media_type === 'VIDEO' || m.media_type === 'REELS');\nreturn videos.map(v => ({ json: { ...cfg, media_id: v.id, permalink: v.permalink, timestamp: v.timestamp, like_count: v.like_count || 0, comments_count: v.comments_count || 0 } }));"
      }
    },
