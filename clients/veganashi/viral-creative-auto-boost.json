      "name": "GET Ads Performance",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [5180, 300],
      "parameters": {
        "method": "GET",
        "url": "=https://graph.facebook.com/v21.0/{{ $('Extraer IDs').first().json.AD_ACCOUNT_ID }}/ads",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "Authorization", "value": "=Bearer {{ $('Extraer IDs').first().json.META_TOKEN }}" }]
