    {
      "id": "node-claude",
      "name": "Claude — Decide Campaña",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [3880, 300],
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key", "value": "={{ $('Extraer IDs').first().json.ANTHROPIC_KEY }}" },
            { "name": "anthropic-version", "value": "2023-06-01" },
            { "name": "content-type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-opus-4-5\",\n  \"max_tokens\": 512,\n  \"messages\": [{\n    \"role\": \"user\",\n    \"content\": \"Eres el estratega de Meta Ads de Veganashi, restaurante vegano en Barcelona. Objetivo: leads + awareness. Budget ~1000€/mes.\\n\\nVideo viral detectado:\\n- ID: {{ $('Ya tiene Ad?').item.json.media_id }}\\n- Views: {{ $('Ya tiene Ad?').item.json.views }}\\n- Saves: {{ $('Ya tiene Ad?').item.json.saves }}\\n- Engagement Rate: {{ $('Ya tiene Ad?').item.json.engagementRate }}\\n- URL: {{ $('Ya tiene Ad?').item.json.permalink }}\\n\\nCampañas activas:\\n{{ JSON.stringify($input.item.json.data, null, 2) }}\\n\\nResponde SOLO con JSON válido (sin markdown):\\n{ \\\"campaign_id\\\": \\\"...\\\", \\\"ad_set_id\\\": \\\"...\\\", \\\"razon\\\": \\\"...\\\" }\\n\\nElige la campaña más adecuada para añadir este creativo viral.\"\n  }]\n}"
      }
    },
    {
      "id": "node-parse-claude",
      "name": "Parsear Claude",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [4140, 300],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const videoData = $('Ya tiene Ad?').item.json;\nconst response = $input.item.json;\nconst text = response.content?.[0]?.text || '{}';\nlet decision;\ntry { decision = JSON.parse(text); } catch(e) { const match = text.match(/\\{[^}]+\\}/s); decision = match ? JSON.parse(match[0]) : { campaign_id: '', ad_set_id: '', razon: 'Parse error' }; }\nreturn { json: { ...videoData, campaign_id: decision.campaign_id, ad_set_id: decision.ad_set_id, claude_razon: decision.razon } };"
      }
    },
